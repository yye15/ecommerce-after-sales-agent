# Copy this file to .env when this project has its own configuration.
# The code also tries to read ../.env so you can reuse the root config.

LLM_API_KEY="your-api-key"
LLM_MODEL_ID="deepseek-chat"
LLM_BASE_URL="https://api.deepseek.com"
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.2

# Optional: local LALUN paths. Leave empty if you only want the main Agent demo.
LALUN_ROOT="external/LALUN/delivery_105"
LALUN_PYTHON="python"
LALUN_CHINESE_MODEL_DIR="external/LALUN/delivery_105/code/output/zh_ecommerce/model"
LALUN_CHINESE_TOKENIZER_DIR="models/hfl_chinese_macbert_base"
USE_LALUN_ENGLISH=0
